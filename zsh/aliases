## homebrew
# alias bud="brew update && echo '\n' && brew outdated --greedy"
bud() {
  brew update

  local json
  json=$(brew outdated --greedy --json)
  local formulae
  formulae=$(echo "$json" | jq -r '.formulae[] | .name + "|" + (.installed_versions | join(", ")) + "|" + .current_version')
  local casks
  casks=$(echo "$json" | jq -r '.casks[] | .name + "|" + (.installed_versions | join(", ")) + "|" + .current_version')
  local output
  output=''

  if [[ -n $formulae ]]; then
    output+='\n\e[4mFormulae\e[24m\n'
    while IFS=$'\n' read -r formula; do
      IFS='|' read -r name installed_versions current_version <<<"$formula"
      output+="$name ($installed_versions) < $current_version\n"
    done <<<"$formulae"
  fi

  if [[ -n $casks ]]; then
    output+='\n\e[4mCasks\e[24m\n'
    while IFS=$'\n' read -r cask; do
      IFS='|' read -r name installed_versions current_version <<<"$cask"
      output+="$name ($installed_versions) < $current_version\n"
    done <<<"$casks"
  fi

  echo -n "$output"
}
