## git
unalias gcp &>/dev/null
# for copying newline separated lists into clipboard as space separated lists
# ex: `git diff --name-only | gcp`
gcp() {
  tee >(tr '\n' ' ' | pbcopy)
}

alias gsh='git show --first-parent'

# copy file paths of listed files in git show
gshc() {
  git show --first-parent --name-only --pretty=format: "$@" | gcp
}

# checkout files from given MRs into current branch
# args: <from_branch> <gitlab MR ref 1> <gitlab MR ref 2> ...
gcmf() {
  local from="$1"
  shift

  readarray -t commit_args < <(git log --format='%h' "${@/*/--grep=&}" "$from")

  readarray -t path_args < <(git show --first-parent --name-only --pretty=format: "${commit_args[@]}" | sort -u | sed '/^[[:space:]]*$/d')

  git checkout "$from" "${path_args[@]}"
}

