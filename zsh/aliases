ug() {
  local tarball
  if [[ "$1" =~ ^http ]]; then
    wget "$1" || return $?
    tarball="$(awk -F '/' '{print $NF}' <<<"$1")"
  else
    tarball="$1"
  fi

  /usr/share/vcinity/configuration/bin/ultx_upgrade.sh -d "$tarball"
}

## lazygit
gl() {
  export LAZYGIT_NEW_DIR_FILE=~/.lazygit/newdir

  lazygit "$@"

  if [ -f $LAZYGIT_NEW_DIR_FILE ]; then
    cd "$(cat $LAZYGIT_NEW_DIR_FILE)"
    rm -f $LAZYGIT_NEW_DIR_FILE >/dev/null
  fi
}

## man
man() {
  if [[ -n $TMUX ]]; then
    local man_path
    man_path=$(command man -w "$@")
    local pane_id
    pane_id=$(tmux display -p '#{s/%%//:pane_id}')
    tmux set-environment "CURRENT_MAN_${pane_id}" "$man_path"

    local win_id
    win_id="$(tmux display -p '#{window_id}')"

    tmux rename-window -t ":$win_id" "man $*"
    command man "$@"
    tmux set-option -wt ":$win_id" automatic-rename on

    tmux set-environment -u "CURRENT_MAN_${pane_id}"
  else
    command man "$@"
  fi
}

## yazi
y() {
  local tmp
  tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
  yazi "$@" --cwd-file="$tmp"
  if cwd="$(command cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
    # shellcheck disable=SC2164
    builtin cd -- "$cwd"
  fi
  rm -f -- "$tmp"
}

